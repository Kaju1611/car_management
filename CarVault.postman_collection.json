{
  "info": {
    "_postman_id": "car-management-collection",
    "name": "CarVault API",
    "description": "Complete API collection for the CarVault Car Management Application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "carId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.test('Registration successful', () => pm.response.to.have.status(201));",
                  "  pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user account. Password must be at least 8 characters with uppercase, lowercase, and a number."
          },
          "response": [
            {
              "name": "Success 201",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Account created successfully\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"_id\": \"66a123abc456def789012345\",\n    \"fullName\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"createdAt\": \"2024-07-25T10:00:00.000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "  pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password. Token is automatically saved to collection variable."
          },
          "response": [
            {
              "name": "Success 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"_id\": \"66a123abc456def789012345\",\n    \"fullName\": \"John Doe\",\n    \"email\": \"john@example.com\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get the currently authenticated user's profile."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "Get All Cars",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cars?page=1&limit=10&sort=-createdAt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "-createdAt", "description": "Use 'createdAt' for oldest first" }
              ]
            },
            "description": "Get all cars belonging to the logged-in user. Supports pagination and sorting."
          },
          "response": []
        },
        {
          "name": "Create Car",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('carId', json.data._id);",
                  "  pm.test('Car created', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "2024 Toyota RAV4 XLE Premium", "type": "text" },
                { "key": "description", "value": "Excellent condition, single owner, full service history. Features include heated seats, sunroof, and advanced safety package.", "type": "text" },
                { "key": "tags[company]", "value": "Toyota", "type": "text" },
                { "key": "tags[carType]", "value": "SUV", "type": "text" },
                { "key": "tags[dealer]", "value": "AutoPlex Motors", "type": "text" },
                { "key": "tags[customTags]", "value": "[\"awd\", \"heated-seats\", \"sunroof\", \"2024\"]", "type": "text" },
                { "key": "images", "type": "file", "src": [], "description": "Upload 1-10 image files" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/cars",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars"]
            },
            "description": "Create a new car listing. Requires multipart/form-data with 1-10 images. Car ID is saved automatically."
          },
          "response": []
        },
        {
          "name": "Search Cars",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cars/search?q=toyota&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars", "search"],
              "query": [
                { "key": "q", "value": "toyota", "description": "Search query" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Search cars across title, description, company, carType, dealer, and customTags fields."
          },
          "response": []
        },
        {
          "name": "Get Car Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cars/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars", "stats"]
            },
            "description": "Get dashboard statistics: total cars, unique companies, and unique dealers for the logged-in user."
          },
          "response": []
        },
        {
          "name": "Get Single Car",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cars/{{carId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars", "{{carId}}"]
            },
            "description": "Get a single car by ID. Only the owner can access."
          },
          "response": []
        },
        {
          "name": "Update Car",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "2024 Toyota RAV4 XLE Premium (Updated)", "type": "text" },
                { "key": "description", "value": "Updated description with more details about the vehicle.", "type": "text" },
                { "key": "tags[company]", "value": "Toyota", "type": "text" },
                { "key": "tags[carType]", "value": "SUV", "type": "text" },
                { "key": "tags[dealer]", "value": "AutoPlex Motors", "type": "text" },
                { "key": "tags[customTags]", "value": "[\"awd\", \"heated-seats\", \"2024\", \"updated\"]", "type": "text" },
                { "key": "existingImages", "value": "[]", "type": "text", "description": "JSON array of existing Cloudinary URLs to keep" },
                { "key": "images", "type": "file", "src": [], "description": "New images to add (optional)" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/cars/{{carId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars", "{{carId}}"]
            },
            "description": "Update a car. Send existingImages as a JSON array of URLs to keep. Add new images as files. Only the owner can update."
          },
          "response": []
        },
        {
          "name": "Delete Car",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cars/{{carId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cars", "{{carId}}"]
            },
            "description": "Delete a car and all its Cloudinary images. Only the owner can delete."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the server is running."
          },
          "response": []
        },
        {
          "name": "Swagger Docs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/docs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "docs"]
            },
            "description": "Open the interactive Swagger UI documentation in browser."
          },
          "response": []
        }
      ]
    }
  ]
}
